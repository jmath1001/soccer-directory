{
  "version": 2,
  "builds": [
    {
      "src": "next.config.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/sitemap\\.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/sitemap-(.*)\\.xml",
      "dest": "/sitemap-$1.xml"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/robots.txt"
    }
  ]
}
